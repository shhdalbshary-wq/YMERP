<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@drawable/card_background"
    android:elevation="4dp">

    <!-- الصورة الشخصية -->
    <RelativeLayout
        android:layout_width="80dp"
        android:layout_height="80dp">

        <ImageView
            android:id="@+id/imgUserPhoto"
            android:src="@drawable/user_photo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@drawable/circle_gold"/>

        <!-- حالة المستخدم -->
        <View
            android:id="@+id/userStatus"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentRight="true"
            android:background="@drawable/status_indicator_green"/>
    </RelativeLayout>

    <!-- بيانات المستخدم -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingLeft="16dp">

        <TextView
            android:id="@+id/tvUserName"
            android:text="مدين الحكيمي / Madyan AL-hakimi"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/arial"/>

        <TextView
            android:id="@+id/tvUserId"
            android:text="رقم المستخدم: 1001"
            android:textSize="14sp"
            android:fontFamily="@font/arial"/>

        <TextView
            android:id="@+id/tvSubscriber"
            android:text="رقم المشترك: 2001"
            android:textSize="14sp"
            android:fontFamily="@font/arial"/>

        <TextView
            android:id="@+id/tvBranch"
            android:text="رقم الفرع: 3001"
            android:textSize="14sp"
            android:fontFamily="@font/arial"/>

        <TextView
            android:id="@+id/tvUnit"
            android:text="الوحدة المحاسبية: 4001"
            android:textSize="14sp"
            android:fontFamily="@font/arial"/>

        <TextView
            android:id="@+id/tvFiscalYear"
            android:text="السنة المالية: 2026"
            android:textSize="14sp"
            android:fontFamily="@font/arial"/>
    </LinearLayout>
</LinearLayout>
